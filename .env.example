# ============ Supabase ============
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-public-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key

# ============ Midtrans ============
# Sandbox keys at https://dashboard.sandbox.midtrans.com/settings/config
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_IS_PRODUCTION=false

# ============ Google Service Account ============
# Buat service account di Google Cloud Console, enable Drive + Sheets API,
# download JSON key, paste email & private_key di bawah.
# private key: jaga newline-nya — paste apa adanya pakai \n literal, runtime akan unescape.
GOOGLE_SERVICE_ACCOUNT_EMAIL=finance-bot@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ============ Resend (email) ============
# Optional — kalau kosong, email aktivasi cuma di-log ke console (tidak gagalkan flow)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=Finance Bot <noreply@your-domain.com>

# ============ App ============
APP_URL=http://localhost:3000

# ============ WAHA (WhatsApp HTTP API) ============
# Untuk kirim activation message ke user setelah bayar & best-effort
# pre-warming LID mapping. Kalau kosong, langkah ini di-skip (non-blocking).
WAHA_URL=http://72.61.208.96:3001
WAHA_SESSION=default
WAHA_API_KEY=your-waha-api-key

# ============ Bypass mode ============
# true  = /api/checkout langsung aktivasi tanpa Midtrans (untuk testing)
# false = wajib selesai bayar di Midtrans Snap, aktivasi terjadi di webhook callback
BYPASS_PAYMENT=true
